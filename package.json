{
  "name": "finflow-iq",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:export": "expo export -p web",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:android": "expo export --platform android --output-dir dist-android",
    "eas:build:development": "eas build -p android --profile development",
    "eas:build:preview": "eas build -p android --profile preview",
    "eas:build:production": "eas build -p android --profile production",
    "eas:update:development": "eas update --channel development",
    "eas:update:preview": "eas update --channel preview",
    "eas:update:production": "npx eas update --channel production",
    "supabase:login": "npx supabase login",
    "supabase:link": "node ./scripts/supabase-link.mjs",
    "supabase:db:push": "npx supabase db push",
    "supabase:db:pull": "npx supabase db pull",
    "supabase:db:clean": "node ./scripts/supabase-reset-db.mjs",
    "supabase:db:seed:test": "node ./scripts/supabase-seed-test-user.mjs",
    "supabase:ai:smoke": "node ./scripts/supabase-ai-smoke.mjs --linked",
    "supabase:config:push": "npx supabase config push",
    "supabase:types": "node ./scripts/supabase-gen-types.mjs"
  },
  "dependencies": {
    "@expo/dom-webview": "55.0.3",
    "@expo/log-box": "55.0.7",
    "@expo/metro-runtime": "~55.0.6",
    "@gorhom/bottom-sheet": "5",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "supabase": "^2.82.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "private": true,
  "repository": "https://github.com/yoelvyspc93/finflow-iq.git",
  "author": "yoelvyspc93",
  "license": "MIT"
}
